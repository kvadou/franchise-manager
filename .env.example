# ── Required ─────────────────────────────────────────────────────────

# PostgreSQL with pgvector extension
DATABASE_URL=postgresql://user:password@localhost:5432/franchise_manager

# NextAuth v5
NEXTAUTH_SECRET=generate-a-random-secret-here
NEXTAUTH_URL=http://localhost:3000
AUTH_TRUST_HOST=true

# Google OAuth (admin authentication)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Optional (app runs in demo mode without these) ───────────────────

# AI — Claude API for chatbot "Earl" and pre-work evaluation
ANTHROPIC_API_KEY=

# AI — OpenAI for vector embeddings (RAG pipeline)
OPENAI_API_KEY=

# Email — Postmark transactional email
POSTMARK_API_KEY=

# Payments — Stripe Connect for royalty collection
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PLATFORM_ACCOUNT_ID=

# Document Signing — Dropbox Sign (HelloSign)
DROPBOX_SIGN_API_KEY=
DROPBOX_SIGN_CLIENT_ID=
DROPBOX_SIGN_TEST_MODE=true
DROPBOX_SIGN_WEBHOOK_SECRET=

# Mapping — Mapbox (public token for client-side maps)
NEXT_PUBLIC_MAPBOX_TOKEN=
# Mapbox secret token for server-side geocoding
MAPBOX_SECRET_TOKEN=

# Canva Integration (creative assets)
CANVA_CLIENT_ID=
CANVA_CLIENT_SECRET=

# Cron job authentication
CRON_SECRET=
