  fileName     String?
  textResponse String? @db.Text // Written response (TEXT_RESPONSE verification)
  completedBy  String? // "franchisee" or "franchisor" or email
  notes        String? @db.Text
  collectedData Json?  // Structured data from module data collection fields

  // Quiz tracking
  quizScore    Int? // Quiz percentage
  quizAttempts Int  @default(0)

  // Legacy field
  score Int? // Old quiz score — replaced by quizScore

  prospect      Prospect               @relation(fields: [prospectId], references: [id], onDelete: Cascade)
  module        AcademyModule          @relation(fields: [moduleId], references: [id], onDelete: Cascade)
