// ============================================
// 90-DAY JOURNEY (Story Time Academy)
// ============================================

// Module ownership types
enum ModuleOwner {
  FRANCHISEE // They do it, may upload proof
  FRANCHISOR // Admin does it for them
  COLLABORATIVE // Both parties involved
}

// Task verification requirements
enum VerificationType {
  CHECKBOX // Just mark complete
  FILE_UPLOAD // Must upload documentation
  TEXT_RESPONSE // Describe what they did
  FRANCHISOR_CONFIRMS // Franchisor marks complete
}

// Franchisor to-do items (created when franchisee needs franchisor action)
model FranchisorTodo {
  id String @id @default(cuid())

  prospectId String
  prospect   Prospect @relation(fields: [prospectId], references: [id], onDelete: Cascade)

  moduleId String?
  module   AcademyModule? @relation("ModuleTodos", fields: [moduleId], references: [id], onDelete: Cascade)

  actionText String // "Set up G Suite for John Smith"
  status     FranchisorTodoStatus @default(PENDING)

  completedAt  DateTime?
  sentEmailId  String?   // Links to auto-sent completion email
  sentEmailAt  DateTime? // When the completion email was sent

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([prospectId])
  @@index([moduleId])
  @@index([status])
}

enum FranchisorTodoStatus {
  PENDING
  COMPLETED
  SKIPPED
}

// Content block types for rich content (unified)
enum ContentBlockType {
  TEXT // Rich text content from TipTap
  CHECKPOINT // Must acknowledge to proceed
  QUIZ // Multiple choice question
  IMAGE // Image with optional caption
  VIDEO // Embedded video (YouTube/Vimeo)
  FILE // Downloadable attachment
  CALLOUT // Tip, warning, or important note
  CHECKLIST // Interactive checklist with items
}

// ============================================
// CONTENT BLOCKS
// ============================================

// Rich content blocks within academy modules (unified system)
model ContentBlock {
  id       String           @id @default(cuid())
  moduleId String
  module   AcademyModule    @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  type     ContentBlockType
  order    Int

  // For TEXT blocks
  content String? @db.Text // HTML from TipTap

  // For CHECKPOINT blocks
  checkpointText String?

  // For QUIZ blocks
  quizQuestion    String?
  quizOptions     Json? // ["Option A", "Option B", "Option C"]
  correctAnswer   Int? // Index of correct option (0-based)
  quizExplanation String? // Shown after answering

  // For IMAGE blocks
  imageUrl     String?
  imageAlt     String?
  imageCaption String?

  // For VIDEO blocks
  videoUrl      String?
  videoProvider String? // "youtube" | "vimeo"

  // For FILE blocks
  fileUrl         String?
  fileTitle       String?
  fileDescription String?

  // For CALLOUT blocks
  calloutType    String? // "tip" | "warning" | "important"
  calloutTitle   String?
  calloutContent String? @db.Text

  // For CHECKLIST blocks
  checklistTitle String?
  checklistItems Json? // [{ title, description, helpLink, dueDay, points }]

  progress ContentBlockProgress[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([moduleId])
}

// Track checkpoint/quiz/checklist completion per franchisee per block
model ContentBlockProgress {
  id String @id @default(cuid())

  progressId String
  progress   AcademyProgress @relation(fields: [progressId], references: [id], onDelete: Cascade)

  blockId String
  block   ContentBlock @relation(fields: [blockId], references: [id], onDelete: Cascade)

  completed   Boolean   @default(false)
  response    String?   @db.Text // Quiz answer text or other response
  correct     Boolean? // Quiz correctness
  completedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([progressId, blockId])
  @@index([progressId])
  @@index([blockId])
}

// ============================================
// WORKFLOW AUTOMATION
// ============================================

model WorkflowTrigger {
  id            String      @id @default(cuid())
  name          String
  description   String?     @db.Text
  triggerType   TriggerType
  triggerConfig Json // Configuration specific to trigger type
  isActive      Boolean     @default(true)
  flowData      Json?       // React Flow canvas state: { nodes, edges, viewport }
  category      String?     // "connection" | "conversion" | "retention" | "custom"
  isTemplate    Boolean     @default(false)

  actions    WorkflowAction[]
  conditions WorkflowCondition[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([triggerType])
  @@index([isActive])
}

enum TriggerType {
  NEW_INQUIRY
  STAGE_CHANGE
  TIME_DELAY
  INACTIVITY
  FORM_SUBMITTED
  PREWORK_COMPLETED
  MANUAL
}

model WorkflowAction {
  id           String     @id @default(cuid())
  triggerId    String
  actionType   ActionType
  actionConfig Json // Configuration specific to action type
  delayMinutes Int        @default(0) // Delay before executing action
  order        Int        @default(0) // Execution order
  nodeId       String?    // React Flow node ID for canvas mapping

  trigger    WorkflowTrigger     @relation(fields: [triggerId], references: [id], onDelete: Cascade)
  executions WorkflowExecution[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([triggerId])
}

enum ActionType {
  SEND_EMAIL
  CREATE_TASK
  CHANGE_STAGE
  NOTIFY_ADMIN
  ADD_NOTE
  WAIT
}

model WorkflowExecution {
  id           String          @id @default(cuid())
  actionId     String
  prospectId   String
  status       ExecutionStatus @default(PENDING)
  result       Json? // Result data from execution
  errorMessage String?
  scheduledFor DateTime? // When this should execute (for delayed actions)
  executedAt   DateTime?
  nodeId           String?
  resumeFromNodeId String?

  action   WorkflowAction @relation(fields: [actionId], references: [id], onDelete: Cascade)
  prospect Prospect       @relation(fields: [prospectId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([actionId])
  @@index([prospectId])
  @@index([status])
  @@index([scheduledFor])
}

enum ExecutionStatus {
  PENDING
  SCHEDULED
  RUNNING
  COMPLETED
  FAILED
  CANCELLED
}

model WorkflowCondition {
  id        String @id @default(cuid())
  triggerId String
  nodeId    String

  field     String
  operator  String
  value     String

  trigger   WorkflowTrigger @relation(fields: [triggerId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([triggerId])
}

// ============================================
// LEAD ATTRIBUTION
// ============================================

model LeadAttribution {
  id         String @id @default(cuid())
  prospectId String @unique

  // First touch attribution
  utmSource      String?
  utmMedium      String?
  utmCampaign    String?
  utmTerm        String?
  utmContent     String?
  referrer       String?
  landingPage    String?
  firstTouchedAt DateTime @default(now())

  prospect Prospect           @relation(fields: [prospectId], references: [id], onDelete: Cascade)
  touches  AttributionTouch[]
}

model AttributionTouch {
  id            String  @id @default(cuid())
  attributionId String
  touchType     String // page_view, form_submit, earl_chat, etc.
  utmSource     String?
  utmMedium     String?
  utmCampaign   String?
  pageUrl       String?

  touchedAt DateTime @default(now())

  attribution LeadAttribution @relation(fields: [attributionId], references: [id], onDelete: Cascade)

  @@index([attributionId])
  @@index([touchedAt])
}

// ============================================
// FRANCHISE FINANCIAL MANAGEMENT
// ============================================

// Franchisee financial account (extends Prospect at SELECTED stage)
model FranchiseeAccount {
  id         String   @id @default(cuid())
  prospectId String   @unique
  prospect   Prospect @relation(fields: [prospectId], references: [id], onDelete: Cascade)

  // Business Information
  ein                  String? // Federal Employer ID
  llcName              String? // Legal entity name
  stateOfIncorporation String? // State where LLC formed
  businessAddress      Json? // Full address { street, city, state, zip }

  // Banking Information
  bankName         String?
  bankAccountLast4 String?
  bankRoutingLast4 String?

  // Insurance
  insurancePolicyNumber  String?
  insuranceCarrier       String?
  insuranceExpiry        DateTime?
  insuranceCoverageType  String?
  insuranceEffectiveDate DateTime?
  insuranceCOIUrl        String?   // Certificate of Insurance file URL

  // Launch Information
  launchDate    DateTime?
  tcInstanceUrl String? // TutorCruncher dashboard URL

  // TutorCruncher connection
  tutorCruncherId    String? // TC branch/agency ID
  tutorCruncherToken String? // Encrypted API token for their instance
  tutorCruncherBase  String? // API base URL

  // Stripe Connect
  stripeAccountId   String? // Connected account ID (acct_xxx)
  stripeOnboarded   Boolean   @default(false)
  stripeOnboardedAt DateTime?

  // Custom profile data collected from onboarding modules
  profileData Json? // { "business_entity_type": "LLC", ... }

  // Financial summary (cached from TC)
  currentMonthRevenue Decimal?  @db.Decimal(10, 2)
  ytdRevenue          Decimal?  @db.Decimal(10, 2)
  lastSyncAt          DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Multi-Unit Support
  isMultiUnit  Boolean      @default(false)
  operatorType OperatorType @default(SINGLE_UNIT)

  // Development agreement (for area developers)
  developmentAgreementId String?
  developmentAgreement   DevelopmentAgreement? @relation(fields: [developmentAgreementId], references: [id])

  // Relations
  invoices       RoyaltyInvoice[]
  payments       RoyaltyPayment[]
  ledgerEntries  LedgerEntry[]
  tcSnapshots    TutorCruncherSnapshot[]
  royaltyConfig  RoyaltyConfig?
  certifications FranchiseeCertification[]
  contacts       FranchiseeContact[]
  markets        Market[] // One-to-many territories
  documents      FranchiseeDocument[]

  // Phase 3 Relations
  franchiseAgreement FranchiseAgreement?
  healthScores       HealthScore[]
  posIntegration     POSIntegration?
  posTransactions    POSTransaction[]

  @@index([stripeAccountId])
  @@index([developmentAgreementId])
}

// Franchisee contact person (multiple contacts per franchisee)
model FranchiseeContact {
  id                String            @id @default(cuid())
  franchiseeId      String
  franchiseeAccount FranchiseeAccount @relation(fields: [franchiseeId], references: [id], onDelete: Cascade)
  contactType       ContactType
  firstName         String
  lastName          String
  email             String?
  phone             String?
  isPrimary         Boolean           @default(false)
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  @@index([franchiseeId])
}

enum ContactType {
  PRIMARY_OWNER
  SPOUSE_PARTNER
  OPERATIONS
  ACCOUNTING
  EMERGENCY
}

enum OperatorType {
  SINGLE_UNIT
  MULTI_UNIT
  AREA_DEVELOPER
  REGIONAL_DEVELOPER
  MASTER_FRANCHISEE
}

// Development agreement for multi-unit / area developers
model DevelopmentAgreement {
  id String @id @default(cuid())

  // Agreement details
  totalUnits     Int // Committed number of units
  developmentFee Decimal @db.Decimal(10, 2)

  // Timeline
  startDate DateTime
  endDate   DateTime // Must open all units by this date

  // Schedule - array of { unitNumber, deadline, status, marketId? }
  schedule Json

  // Relations
  franchiseeAccounts FranchiseeAccount[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Monthly TutorCruncher data snapshot (for audit trail)
model TutorCruncherSnapshot {
  id                  String            @id @default(cuid())
  franchiseeAccountId String
  franchiseeAccount   FranchiseeAccount @relation(fields: [franchiseeAccountId], references: [id], onDelete: Cascade)

  year  Int
  month Int

  // Revenue breakdown
  grossRevenue  Decimal  @db.Decimal(10, 2)
  homeRevenue   Decimal? @db.Decimal(10, 2)
  onlineRevenue Decimal? @db.Decimal(10, 2)
  retailRevenue Decimal? @db.Decimal(10, 2)
  schoolRevenue Decimal? @db.Decimal(10, 2)
  otherRevenue  Decimal? @db.Decimal(10, 2)

  // Activity metrics (for leaderboard)
  totalLessons   Int?
  totalHours     Decimal? @db.Decimal(10, 2)
  activeStudents Int?
  activeTutors   Int?

  // Raw data for verification
  rawData Json // Full TC response for audit

  createdAt DateTime @default(now())

  @@unique([franchiseeAccountId, year, month])
  @@index([franchiseeAccountId])
  @@index([year, month])
}

// Royalty configuration (global + per-franchisee overrides)
model RoyaltyConfig {
  id                  String             @id @default(cuid())
  franchiseeAccountId String?            @unique // null = global default
  franchiseeAccount   FranchiseeAccount? @relation(fields: [franchiseeAccountId], references: [id], onDelete: Cascade)

  royaltyPercent    Decimal @default(7.0) @db.Decimal(5, 2)
  brandFundPercent  Decimal @default(1.0) @db.Decimal(5, 2)
  systemsFeePercent Decimal @default(2.0) @db.Decimal(5, 2)

  // Optional minimums/caps
  minimumMonthlyFee Decimal? @db.Decimal(10, 2)
  maximumMonthlyFee Decimal? @db.Decimal(10, 2)

  effectiveFrom DateTime  @default(now())
  effectiveTo   DateTime?

  notes String? @db.Text // For documenting special agreements

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Monthly royalty invoice
model RoyaltyInvoice {
  id                  String            @id @default(cuid())
  invoiceNumber       String            @unique // INV-2026-02-001
  franchiseeAccountId String
  franchiseeAccount   FranchiseeAccount @relation(fields: [franchiseeAccountId], references: [id], onDelete: Cascade)

  year  Int
  month Int

  // Revenue basis
  grossRevenue Decimal @db.Decimal(10, 2)

  // Itemized fees
  royaltyAmount     Decimal @db.Decimal(10, 2) // 7%
  royaltyPercent    Decimal @db.Decimal(5, 2) // Store rate for historical accuracy
  brandFundAmount   Decimal @db.Decimal(10, 2) // 1%
  brandFundPercent  Decimal @db.Decimal(5, 2)
  systemsFeeAmount  Decimal @db.Decimal(10, 2) // 2%
  systemsFeePercent Decimal @db.Decimal(5, 2)
  totalAmount       Decimal @db.Decimal(10, 2) // 10%

  // Adjustments
  adjustmentAmount Decimal? @db.Decimal(10, 2)
  adjustmentReason String?  @db.Text

  // Status workflow
  status InvoiceStatus @default(DRAFT)

  // Franchisee verification
  sentToFranchiseeAt   DateTime?
  franchiseeReviewedAt DateTime?
  franchiseeApproved   Boolean?
  franchiseeNotes      String?   @db.Text

  // Dates
  invoiceDate DateTime
  dueDate     DateTime
  paidAt      DateTime?

  // Stripe payment intent (if using auto-collect)
  stripePaymentIntentId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  payments RoyaltyPayment[]

  @@unique([franchiseeAccountId, year, month])
  @@index([franchiseeAccountId])
  @@index([status])
  @@index([year, month])
}

enum InvoiceStatus {
  DRAFT // Being prepared
  PENDING_REVIEW // Sent to franchisee for verification
  APPROVED // Franchisee verified
  DISPUTED // Franchisee raised concerns
  PAYMENT_PENDING // Ready for payment
  PROCESSING // Payment in progress
  PAID // Payment received
  OVERDUE // Past due date
  CANCELLED // Voided
}

// Payment records
model RoyaltyPayment {
  id                  String            @id @default(cuid())
  invoiceId           String
  invoice             RoyaltyInvoice    @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  franchiseeAccountId String
  franchiseeAccount   FranchiseeAccount @relation(fields: [franchiseeAccountId], references: [id], onDelete: Cascade)

  amount Decimal       @db.Decimal(10, 2)
  method PaymentMethod

  // Stripe details
  stripePaymentIntentId String?
  stripeTransferId      String?
  stripeChargeId        String?

  status PaymentStatus @default(PENDING)

  processedAt   DateTime?
  failureReason String?
  notes         String?   @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([invoiceId])
  @@index([franchiseeAccountId])
  @@index([status])
}

enum PaymentMethod {
  STRIPE_CONNECT
  STRIPE_ACH
  ACH_DIRECT
  CHECK
  WIRE
  MANUAL
}

enum PaymentStatus {
  PENDING
  PROCESSING
  SUCCEEDED
  FAILED
  REFUNDED
  CANCELLED
}

// Immutable financial ledger for audit trail
model LedgerEntry {
  id                  String            @id @default(cuid())
  franchiseeAccountId String
  franchiseeAccount   FranchiseeAccount @relation(fields: [franchiseeAccountId], references: [id], onDelete: Cascade)

  entryType    LedgerEntryType
  amount       Decimal         @db.Decimal(10, 2)
  balanceAfter Decimal         @db.Decimal(10, 2)

  description   String
  referenceType String? // "invoice", "payment", "adjustment"
  referenceId   String?

  createdAt DateTime @default(now())
  // No updatedAt - ledger entries are immutable

  @@index([franchiseeAccountId])
  @@index([createdAt])
}

enum LedgerEntryType {
  INVOICE_CREATED
  PAYMENT_RECEIVED
  ADJUSTMENT_CREDIT
  ADJUSTMENT_DEBIT
  REFUND
}

// ============================================
// CERTIFICATIONS & COMPLIANCE
// ============================================

model Certification {
  id                String                @id @default(cuid())
  slug              String                @unique
  name              String
  description       String?               @db.Text
  requiredForLaunch Boolean               @default(false)
  renewalMonths     Int? // null = no renewal required
  category          CertificationCategory @default(TRAINING)

  franchiseeCerts FranchiseeCertification[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum CertificationCategory {
  TRAINING
  COMPLIANCE
  LEGAL
  INSURANCE
  OPERATIONS
}

model FranchiseeCertification {
  id                  String            @id @default(cuid())
  franchiseeAccountId String
  franchiseeAccount   FranchiseeAccount @relation(fields: [franchiseeAccountId], references: [id], onDelete: Cascade)
  certificationId     String
  certification       Certification     @relation(fields: [certificationId], references: [id], onDelete: Cascade)

  earnedAt  DateTime
  expiresAt DateTime?
  status    CertStatus @default(ACTIVE)

  // Supporting documents
  documentUrl  String?
  documentName String?

  // Renewal tracking
  renewalReminderSent Boolean @default(false)
  renewedFromId       String? // If this is a renewal, link to previous cert

  notes String? @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([franchiseeAccountId, certificationId])
  @@index([franchiseeAccountId])
  @@index([certificationId])
  @@index([status])
  @@index([expiresAt])
}

enum CertStatus {
  ACTIVE
  EXPIRING_SOON // 30 days before expiration
  EXPIRED
  REVOKED
}

// ============================================
// OPERATIONS MANUAL
// ============================================

model ManualSection {
  id          String  @id @default(cuid())
  title       String
  slug        String  @unique
  description String? @db.Text
  icon        String? // Emoji
  sortOrder   Int     @default(0)

  pages ManualPage[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([sortOrder])
}

model ManualPage {
  id                     String           @id @default(cuid())
  sectionId              String
  section                ManualSection    @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  title                  String
  slug                   String           @unique
  content                String           @db.Text
  excerpt                String?          @db.Text
  sortOrder              Int              @default(0)
  status                 ManualPageStatus @default(DRAFT)
  requiresAcknowledgment Boolean          @default(false)
  currentVersion         Int              @default(1)
  publishedAt            DateTime?
  publishedBy            String?

  versions        ManualPageVersion[]
  acknowledgments ManualAcknowledgment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([sectionId])
  @@index([status])
  @@index([sortOrder])
}

enum ManualPageStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

model ManualPageVersion {
  id            String               @id @default(cuid())
  pageId        String
  page          ManualPage           @relation(fields: [pageId], references: [id], onDelete: Cascade)
  versionNumber Int
  content       String               @db.Text
  changeType    ManualPageChangeType @default(MINOR)
  changeSummary String?
  createdBy     String

  createdAt DateTime @default(now())

  @@unique([pageId, versionNumber])
  @@index([pageId])
}

enum ManualPageChangeType {
  MAJOR
  MINOR
}

model ManualAcknowledgment {
  id             String     @id @default(cuid())
  prospectId     String
  prospect       Prospect   @relation(fields: [prospectId], references: [id], onDelete: Cascade)
  pageId         String
  page           ManualPage @relation(fields: [pageId], references: [id], onDelete: Cascade)
  versionNumber  Int
  acknowledgedAt DateTime   @default(now())

  @@unique([prospectId, pageId])
  @@index([prospectId])
  @@index([pageId])
}

// ============================================
// HELP DESK / SUPPORT TICKETS
// ============================================

model SupportTicket {
  id           String         @id @default(cuid())
  ticketNumber String         @unique // Format: TKT-YYYY-XXXXX
  subject      String
  description  String         @db.Text
  category     TicketCategory
  priority     TicketPriority @default(MEDIUM)
  status       TicketStatus   @default(OPEN)

  // Submitter (franchisee)
  prospectId String
  prospect   Prospect @relation(fields: [prospectId], references: [id], onDelete: Cascade)

  // Assignment
  assignedTo String?
  assignedAt DateTime?

  // Resolution
  resolvedAt DateTime?
  resolvedBy String?
  resolution String?   @db.Text

  // SLA tracking
  firstResponseAt DateTime?
  slaDeadline     DateTime?

  comments SupportTicketComment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([prospectId])
  @@index([status])
  @@index([priority])
  @@index([assignedTo])
  @@index([createdAt])
}

enum TicketCategory {
  TECHNICAL
  BILLING
  OPERATIONS
  MARKETING
  TRAINING
  COMPLIANCE
  OTHER
}

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  WAITING_ON_FRANCHISEE
  WAITING_ON_ADMIN
  RESOLVED
  CLOSED
}

model SupportTicketComment {
  id       String        @id @default(cuid())
  ticketId String
  ticket   SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  authorEmail String
  authorName  String
  authorRole  String // "ADMIN" or "FRANCHISEE"
  content     String  @db.Text
  isInternal  Boolean @default(false)

  createdAt DateTime @default(now())

  @@index([ticketId])
}

// ============================================
// FIELD AUDITS
// ============================================

model AuditTemplate {
  id          String        @id @default(cuid())
  name        String
  slug        String        @unique
  description String?       @db.Text
  category    AuditCategory
  isActive    Boolean       @default(true)

  items  AuditTemplateItem[]
  audits FieldAudit[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum AuditCategory {
  BRAND_STANDARDS
  OPERATIONS
  SAFETY
  MARKETING
  CUSTOMER_EXPERIENCE
}

model AuditTemplateItem {
  id         String        @id @default(cuid())
  templateId String
  template   AuditTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  question    String
  description String?       @db.Text
  itemType    AuditItemType @default(PASS_FAIL)
  weight      Int           @default(1)
  sortOrder   Int           @default(0)
  isRequired  Boolean       @default(true)

  responses AuditResponse[]

  @@index([templateId])
}

enum AuditItemType {
  PASS_FAIL
  RATING_1_5
  YES_NO
  TEXT
  PHOTO
}

model FieldAudit {
  id         String        @id @default(cuid())
  templateId String
  template   AuditTemplate @relation(fields: [templateId], references: [id])

  prospectId String
  prospect   Prospect @relation(fields: [prospectId], references: [id], onDelete: Cascade)

  auditorEmail String
  auditorName  String

  status        AuditStatus @default(IN_PROGRESS)
  scheduledDate DateTime?
  completedAt   DateTime?
  overallScore  Float?
  notes         String?     @db.Text

  responses         AuditResponse[]
  correctiveActions CorrectiveAction[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([prospectId])
  @@index([status])
  @@index([scheduledDate])
}

enum AuditStatus {
  SCHEDULED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

model AuditResponse {
  id      String            @id @default(cuid())
  auditId String
  audit   FieldAudit        @relation(fields: [auditId], references: [id], onDelete: Cascade)
  itemId  String
  item    AuditTemplateItem @relation(fields: [itemId], references: [id], onDelete: Cascade)

  value    String
  score    Float?
  notes    String? @db.Text
  photoUrl String?

  @@unique([auditId, itemId])
  @@index([auditId])
}

model CorrectiveAction {
  id      String     @id @default(cuid())
  auditId String
  audit   FieldAudit @relation(fields: [auditId], references: [id], onDelete: Cascade)

  description String                 @db.Text
  assignedTo  String
  dueDate     DateTime
  status      CorrectiveActionStatus @default(OPEN)
  completedAt DateTime?
  completedBy String?
  evidence    String?
  adminNotes  String?                @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([auditId])
  @@index([status])
  @@index([dueDate])
}

enum CorrectiveActionStatus {
  OPEN
  IN_PROGRESS
  COMPLETED
  OVERDUE
  WAIVED
}

// ============================================
// PHASE 3: FRANCHISE AGREEMENT & RENEWAL MANAGEMENT
// ============================================

model FranchiseAgreement {
  id                  String            @id @default(cuid())
  franchiseeAccountId String            @unique
  franchiseeAccount   FranchiseeAccount @relation(fields: [franchiseeAccountId], references: [id], onDelete: Cascade)

  // Agreement details
  agreementNumber String   @unique // FA-2026-001
  version         Int      @default(1)
  startDate       DateTime
  endDate         DateTime // Original term end date
  termYears       Int      @default(10) // Standard franchise term

  // Territory reference
  territoryDescription String? @db.Text
  exclusiveTerritory   Boolean @default(true)

  // Financial terms captured at signing
  initialFranchiseFee Decimal @db.Decimal(10, 2)
  royaltyPercent      Decimal @db.Decimal(5, 2)
  brandFundPercent    Decimal @db.Decimal(5, 2)
  systemsFeePercent   Decimal @db.Decimal(5, 2)

  // Renewal terms
  renewalTermYears       Int      @default(10) // Term for renewals
  renewalFee             Decimal? @db.Decimal(10, 2) // Renewal franchise fee
  renewalNoticeMonths    Int      @default(6) // Months notice required for renewal
  nonRenewalNoticeMonths Int      @default(6) // Months notice for non-renewal

  // Status tracking
  status AgreementStatus @default(ACTIVE)

  // Document reference
  documentUrl String?
  signedAt    DateTime?
  signedBy    String?
  witnessedBy String?

  // Relations
  renewals AgreementRenewal[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([endDate])
}

enum AgreementStatus {
  DRAFT
  PENDING_SIGNATURE
  ACTIVE
  RENEWAL_ELIGIBLE // Within renewal window
  RENEWAL_IN_PROGRESS
  RENEWED
  TERMINATED
  EXPIRED
  TRANSFERRED
}

model AgreementRenewal {
  id          String             @id @default(cuid())
  agreementId String
  agreement   FranchiseAgreement @relation(fields: [agreementId], references: [id], onDelete: Cascade)

  // Renewal tracking
  renewalNumber Int // 1st renewal, 2nd renewal, etc.
  initiatedAt   DateTime @default(now())
  initiatedBy   String // SYSTEM, admin email, or franchisee

  // Timeline
  notificationSentAt DateTime? // When renewal notice was sent
  responseDeadline   DateTime? // When franchisee must respond
  effectiveDate      DateTime? // When new term starts

  // Renewal terms (may differ from original)
  newTermYears      Int?
  newEndDate        DateTime?
  renewalFee        Decimal?  @db.Decimal(10, 2)
  newRoyaltyPercent Decimal?  @db.Decimal(5, 2)
  feeWaived         Boolean   @default(false)
  feeWaivedReason   String?   @db.Text

  // Status workflow
  status RenewalStatus @default(PENDING_NOTICE)

  // Franchisee response
  franchiseeIntentAt DateTime?
  franchiseeIntent   RenewalIntent?
  franchiseeNotes    String?        @db.Text

  // Franchisor decision
  franchisorDecisionAt DateTime?
  franchisorDecision   RenewalDecision?
  franchisorNotes      String?          @db.Text
  decisionBy           String?

  // Document references
  renewalAgreementUrl String?
  signedAt            DateTime?

  // Non-renewal / Termination
  terminationReason      String?   @db.Text
  terminationEffectiveAt DateTime?

  // Transfer (if applicable)
  transferToProspectId String?
  transferApprovedAt   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([agreementId, renewalNumber])
  @@index([agreementId])
  @@index([status])
  @@index([effectiveDate])
}

enum RenewalStatus {
  PENDING_NOTICE // Not yet in renewal window
  NOTICE_SENT // 12/6/3 month notices sent
  AWAITING_RESPONSE // Waiting for franchisee decision
  INTENT_RECEIVED // Franchisee responded
  UNDER_REVIEW // Franchisor reviewing
  NEGOTIATING // Terms being negotiated
  APPROVED // Renewal approved
  DECLINED // Franchisor declined renewal
  NON_RENEWAL // Franchisee chose not to renew
  COMPLETED // New agreement signed
  TERMINATED // Agreement terminated early
  TRANSFERRED // Franchise transferred to new owner
}

enum RenewalIntent {
  RENEW
  NOT_RENEWING
  CONSIDERING
  TRANSFER_REQUESTED
}

enum RenewalDecision {
  APPROVE_RENEWAL
  APPROVE_WITH_CONDITIONS
  DENY_RENEWAL
  APPROVE_TRANSFER
  TERMINATE
}

// ============================================
// PHASE 3: ADVANCED ANALYTICS & REPORTING
// ============================================

model CustomReport {
  id          String  @id @default(cuid())
  name        String
  slug        String  @unique
  description String? @db.Text

  // Report definition
  reportType ReportType
  dataSource String // Table/entity to query
  metrics    Json // Array of metric definitions { field, aggregation, label }
  dimensions Json // Array of dimension definitions { field, label }
  filters    Json // Default filters { field, operator, value }
  sortBy     Json? // { field, direction }

  // Display options
  chartType   ChartType?
  chartConfig Json? // Chart-specific configuration

  // Access control
  isSystem  Boolean @default(false) // Built-in reports
  isPublic  Boolean @default(false) // Available to franchisees
  createdBy String

  // Schedule (optional)
  schedules ReportSchedule[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([reportType])
  @@index([createdBy])
}

enum ReportType {
  FINANCIAL
  OPERATIONAL
  COMPLIANCE
  MARKETING
  PERFORMANCE
  CUSTOM
}

enum ChartType {
  LINE
  BAR
  PIE
  DONUT
  AREA
  TABLE
  KPI
  HEATMAP
}

model ReportSchedule {
  id       String       @id @default(cuid())
  reportId String
  report   CustomReport @relation(fields: [reportId], references: [id], onDelete: Cascade)

  // Schedule configuration
  frequency  ScheduleFrequency
  dayOfWeek  Int? // 0-6 for weekly
  dayOfMonth Int? // 1-31 for monthly
  time       String // HH:MM in UTC

  // Recipients
  recipients String[] // Array of email addresses
  format     ExportFormat @default(PDF)

  // Status
  isActive  Boolean   @default(true)
  lastRunAt DateTime?
  nextRunAt DateTime?
  lastError String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([reportId])
  @@index([nextRunAt])
  @@index([isActive])
}

enum ScheduleFrequency {
  DAILY
  WEEKLY
  MONTHLY
  QUARTERLY
}

enum ExportFormat {
  PDF
  EXCEL
  CSV
}

// Franchisee Health Score
model HealthScore {
  id                  String            @id @default(cuid())
  franchiseeAccountId String
  franchiseeAccount   FranchiseeAccount @relation(fields: [franchiseeAccountId], references: [id], onDelete: Cascade)

  // Scoring period
  year  Int
  month Int

  // Component scores (0-100)
  financialScore   Float // Revenue growth, collection rate, profitability
  operationalScore Float // Lesson completion, customer satisfaction, retention
  complianceScore  Float // Certifications, audits, document status
  engagementScore  Float // Academy progress, support tickets, communication
  growthScore      Float // New students, market penetration, expansion

  // Overall composite score (weighted average)
  compositeScore Float

  // Risk assessment
  riskLevel   RiskLevel
  riskFactors Json // Array of { factor, impact, description }

  // Trend data
  previousScore Float? // Last month's composite score
  trend         ScoreTrend

  // Detailed breakdown (for drill-down)
  breakdown Json // Full scoring details by category

  // Recommendations
  recommendations Json? // Array of { priority, category, action, impact }

  createdAt DateTime @default(now())

  @@unique([franchiseeAccountId, year, month])
  @@index([franchiseeAccountId])
  @@index([year, month])
  @@index([riskLevel])
  @@index([compositeScore])
}

enum RiskLevel {
  LOW
  MODERATE
  ELEVATED
  HIGH
  CRITICAL
}

enum ScoreTrend {
  IMPROVING
  STABLE
  DECLINING
  NEW // First score, no comparison
}

// Configurable health score weights
model HealthScoreWeight {
  id String @id @default(cuid())

  // Category weights (must sum to 100)
  financialWeight   Float @default(30) // Revenue, collections
  operationalWeight Float @default(25) // Service delivery
  complianceWeight  Float @default(20) // Certs, audits
  engagementWeight  Float @default(15) // Participation
  growthWeight      Float @default(10) // Expansion

  // Sub-component weights within each category (JSON)
  financialComponents   Json // { revenueGrowth: 40, collectionRate: 30, profitMargin: 30 }
  operationalComponents Json
  complianceComponents  Json
  engagementComponents  Json
  growthComponents      Json

  // Thresholds for risk levels
  criticalThreshold Float @default(40) // Below this = CRITICAL
  highRiskThreshold Float @default(55) // Below this = HIGH
  elevatedThreshold Float @default(70) // Below this = ELEVATED
  moderateThreshold Float @default(85) // Below this = MODERATE, above = LOW

  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ============================================
// PHASE 3: POS INTEGRATION FRAMEWORK
// ============================================

model POSIntegration {
  id                  String            @id @default(cuid())
  franchiseeAccountId String            @unique
  franchiseeAccount   FranchiseeAccount @relation(fields: [franchiseeAccountId], references: [id], onDelete: Cascade)

  // POS System
  provider     POSProvider
  providerName String? // For OTHER type

  // Connection details
  apiKey         String?
  accessToken    String?
  refreshToken   String?
  tokenExpiresAt DateTime?
  merchantId     String?
  locationId     String?

  // Connection status
  status         IntegrationStatus @default(PENDING)
  connectedAt    DateTime?
  lastSyncAt     DateTime?
  lastSyncStatus String?
  lastError      String?

  // Sync configuration
  syncFrequency SyncFrequency @default(DAILY)
  syncStartDate DateTime? // Don't sync data before this date
  autoSync      Boolean       @default(true)

  // Data pulled
  syncTransactions Boolean @default(true)
  syncInventory    Boolean @default(false)
  syncCustomers    Boolean @default(false)

  // Revenue mapping (how to categorize POS revenue)
  revenueMapping Json? // { "Chess Club": "retail", "Private Lesson": "home" }

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum POSProvider {
  SQUARE
  STRIPE_TERMINAL
  TOAST
  CLOVER
  SHOPIFY
  TUTORCRUNCHER // Existing integration
  MANUAL
  OTHER
}

enum IntegrationStatus {
  PENDING
  CONNECTING
  CONNECTED
  ERROR
  DISCONNECTED
  EXPIRED
}

enum SyncFrequency {
  REAL_TIME
  HOURLY
  DAILY
  WEEKLY
}

// POS Transaction records (for detailed financial tracking)
model POSTransaction {
  id                  String            @id @default(cuid())
  franchiseeAccountId String
  franchiseeAccount   FranchiseeAccount @relation(fields: [franchiseeAccountId], references: [id], onDelete: Cascade)

  // External reference
  externalId String
  provider   POSProvider
  locationId String?

  // Transaction details
  transactionDate DateTime
  grossAmount     Decimal  @db.Decimal(10, 2)
  netAmount       Decimal  @db.Decimal(10, 2)
  fees            Decimal? @db.Decimal(10, 2)
  tax             Decimal? @db.Decimal(10, 2)

  // Categorization
  category    String? // home, online, retail, school, other
  description String?

  // Line items (JSON array)
  lineItems Json? // [{ name, quantity, unitPrice, total }]

  // Customer reference
  customerName  String?
  customerEmail String?

  // Payment details
  paymentMethod String? // cash, card, etc.
  cardBrand     String?
  cardLast4     String?

  // Status
  status         TransactionStatus @default(COMPLETED)
  refundedAmount Decimal?          @db.Decimal(10, 2)

  // Raw data
  rawData Json? // Original POS response

  syncedAt DateTime @default(now())

  @@unique([franchiseeAccountId, externalId, provider])
  @@index([franchiseeAccountId])
  @@index([transactionDate])
  @@index([category])
}

enum TransactionStatus {
  PENDING
  COMPLETED
  REFUNDED
  PARTIALLY_REFUNDED
  VOIDED
}

// Financial benchmarks (network-wide comparison data)
model FinancialBenchmark {
  id String @id @default(cuid())

  year  Int
  month Int

  // Network-wide metrics
  networkMedianRevenue  Decimal @db.Decimal(10, 2)
  networkAvgRevenue     Decimal @db.Decimal(10, 2)
  networkTopQuartile    Decimal @db.Decimal(10, 2) // 75th percentile
  networkBottomQuartile Decimal @db.Decimal(10, 2) // 25th percentile

  // By category
  medianHomeRevenue   Decimal? @db.Decimal(10, 2)
  medianOnlineRevenue Decimal? @db.Decimal(10, 2)
  medianRetailRevenue Decimal? @db.Decimal(10, 2)
  medianSchoolRevenue Decimal? @db.Decimal(10, 2)

  // Operational benchmarks
  medianLessonsPerMonth Int?
  medianStudentsActive  Int?
  medianTutorsActive    Int?
  avgCustomerRetention  Float?

  // Financial ratios
  avgGrossMargin    Float?
  avgCollectionRate Float?
  avgDaysToPayment  Float?

  // Growth benchmarks
  avgRevenueGrowthMoM Float? // Month-over-month
  avgRevenueGrowthYoY Float? // Year-over-year

  // Sample size
  franchiseeCount Int

  createdAt DateTime @default(now())

  @@unique([year, month])
  @@index([year, month])
}

// ============================================
// INDUSTRY BENCHMARKING MODELS
// ============================================

// Industry benchmark data for competitor/target companies
model IndustryBenchmark {
  id String @id @default(cuid())

  // Company identification
  companyName   String // e.g., "Soccer Shots", "Little Kickers", "Mathnasium"
  companyType   CompanyType @default(COMPETITOR)
  parentCompany String? // e.g., "Stronger Youth Brands"
  category      String // e.g., "youth-sports", "tutoring", "enrichment"

  // Data year
  dataYear Int

  // Scale metrics
  systemWideRevenue  Decimal? @db.Decimal(12, 2) // Total across all units
  franchiseeCount    Int?
  companyOwnedUnits  Int?
  totalUnits         Int?
  countriesOperating Int?
  statesOperating    Int?

  // Unit economics
  avgRevenuePerUnit    Decimal? @db.Decimal(10, 2)
  medianRevenuePerUnit Decimal? @db.Decimal(10, 2)
  topQuartileRevenue   Decimal? @db.Decimal(10, 2) // Top 25% avg
  topPerformerRevenue  Decimal? @db.Decimal(10, 2) // Single best unit

  // Fees
  initialInvestmentLow  Decimal? @db.Decimal(10, 2)
  initialInvestmentHigh Decimal? @db.Decimal(10, 2)
  franchiseFee          Decimal? @db.Decimal(10, 2)
  royaltyRate           Float? // Percentage
  adFundRate            Float? // Percentage

  // Operational metrics
  childrenEnrolled    Int? // Total children served
  territoryPopulation Int? // Population per territory
  avgEBITDAPerUnit    Decimal? @db.Decimal(10, 2)
  operatingMargin     Float? // Percentage

  // Growth metrics
  yoyGrowthRate  Float? // Year-over-year revenue growth
  unitGrowthRate Float? // Year-over-year unit growth

  // Acquisition/funding info
  fundingRaised Decimal? @db.Decimal(12, 2)
  valuation     Decimal? @db.Decimal(12, 2)
  acquiredYear  Int?
  acquiredBy    String?

  // Data source
  dataSource String? // e.g., "FDD Item 19", "Press Release", "Franchise Times"
  sourceUrl  String?
  notes      String? @db.Text

  isActive Boolean @default(true)

  // Staleness tracking
  lastVerifiedAt  DateTime? // When admin last confirmed data is current
  nextRefreshDate DateTime? // When this data should be refreshed

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([companyName, dataYear])
  @@index([category])
  @@index([companyType])
}

enum CompanyType {
  COMPETITOR // Direct competitors
  ACQUISITION_TARGET // Companies we aspire to match
  ACQUIRER // Potential acquirers (e.g., Stronger Youth Brands)
  INDUSTRY_BENCHMARK // General industry data
}

// STC growth milestones and targets
model GrowthMilestone {
  id String @id @default(cuid())

  // Milestone identification
  name         String // e.g., "Year 1", "Year 3", "Acquisition Ready"
  targetYear   Int // Calendar year target
  displayOrder Int    @default(0)

  // Revenue targets
  systemWideRevenueTarget Decimal? @db.Decimal(12, 2)
  avgRevenuePerUnitTarget Decimal? @db.Decimal(10, 2)

  // Scale targets
  franchiseeCountTarget  Int?
  totalUnitsTarget       Int?
  statesTarget           Int?
  childrenEnrolledTarget Int?

  // Financial targets
  operatingMarginTarget     Float?
  franchiseeRetentionTarget Float?

  // Qualitative goals
  keyObjectives Json? // Array of objective strings

  // Comparison reference
  comparableCompany String? // e.g., "Soccer Shots at SYB investment"
  comparableNotes   String? @db.Text

  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([targetYear])
}

// STC actual performance snapshots (for tracking against milestones)
model STCPerformanceSnapshot {
  id String @id @default(cuid())

  // Period
  year    Int
  month   Int
  quarter Int?

  // Revenue metrics
  systemWideRevenue Decimal? @db.Decimal(12, 2)
  avgRevenuePerUnit Decimal? @db.Decimal(10, 2)

  // Scale metrics
  activeFranchisees Int?
  totalTerritories  Int?
  statesOperating   Int?
  childrenEnrolled  Int?

  // Financial metrics
  totalRoyaltiesCollected Decimal? @db.Decimal(10, 2)
  collectionRate          Float?
  avgOperatingMargin      Float?

  // Operational metrics
  totalLessonsDelivered Int?
  avgLessonsPerUnit     Int?
  avgStudentsPerUnit    Int?

  // Growth metrics
  newFranchiseesThisPeriod Int?
  franchiseeChurnRate      Float?
  revenueGrowthMoM         Float?
  revenueGrowthYoY         Float?

  // Notes
  notes String? @db.Text

  createdAt DateTime @default(now())

  @@unique([year, month])
  @@index([year])
}

// ============================================
// ANNOUNCEMENT MODELS
// ============================================

model Announcement {
  id          String               @id @default(cuid())
  title       String
  content     String               @db.Text
  category    AnnouncementCategory
  priority    AnnouncementPriority @default(NORMAL)
  status      AnnouncementStatus   @default(DRAFT)
  publishedAt DateTime?
  expiresAt   DateTime?
  createdBy   String // Admin email
  isPinned    Boolean              @default(false)

  reads     AnnouncementRead[]
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt

  @@index([status, publishedAt])
  @@index([category])
}

model AnnouncementRead {
  id             String   @id @default(cuid())
  announcementId String
  prospectId     String
  readAt         DateTime @default(now())

  announcement Announcement @relation(fields: [announcementId], references: [id], onDelete: Cascade)
  prospect     Prospect     @relation(fields: [prospectId], references: [id], onDelete: Cascade)

  @@unique([announcementId, prospectId])
  @@index([prospectId])
}

