generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// AUTH MODELS (NextAuth)
// ============================================

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  role          UserRole  @default(PROSPECT)
  accounts      Account[]
  sessions      Session[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@id([identifier, token])
}

enum UserRole {
  ADMIN
  REVIEWER
  PROSPECT
}

// ============================================
// PROSPECT & CRM MODELS
// ============================================

model Prospect {
  id           String  @id @default(cuid())
  email        String  @unique
  passwordHash String? // For prospect portal login

  // Portal invite tokens
  inviteToken       String?   @unique
  inviteTokenExpiry DateTime?
  inviteSentAt      DateTime?

  // Password reset tokens
  resetToken       String?   @unique
  resetTokenExpiry DateTime?

  firstName          String
  lastName           String
  phone              String?
  preferredTerritory String?
  interestLevel      InterestLevel
  liquidity          LiquidityRange?
  aboutYourself      String?         @db.Text
  referralSource     String?

  // UTM tracking
  utmSource   String?
  utmMedium   String?
  utmCampaign String?

  // Pipeline & Scoring
  pipelineStage PipelineStage @default(NEW_INQUIRY)
  prospectScore Int           @default(0)
  assignedTo    String? // Admin user email

  // Pre-work tracking
  preWorkStatus      PreWorkStatus @default(NOT_STARTED)
  preWorkStartedAt   DateTime?
  preWorkCompletedAt DateTime?

  // Selection tracking
  selectedAt DateTime? // When prospect was selected (for journey start date)

  // Timestamps
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  lastContactAt DateTime?

  // Relations
  conversations        ChatConversation[]
  preWorkSubmissions   PreWorkSubmission[]
  documents            ProspectDocument[]
  activities           ProspectActivity[]
  notes                ProspectNote[]
  academyProgress      AcademyProgress[]
  earnedBadges         EarnedBadge[]
  dailyActivity        AcademyDailyActivity[]
  pointsLog            AcademyPointsLog[]
  visitors             Visitor[]
  franchisorTodos      FranchisorTodo[]

  // CRM Relations
  emails            CrmEmail[]
  calls             CrmCall[]
  meetings          CrmMeeting[]
  tasks             CrmTask[]
  summary           ProspectSummary?
  preWorkEvaluation PreWorkEvaluation?
  sentEmails        SentEmail[]

  // Automation Relations
  workflowExecutions WorkflowExecution[]
  attribution        LeadAttribution?

  // Franchisee Financial Account (created at SELECTED stage)
  franchiseeAccount FranchiseeAccount?

  // Operations Manual
  manualAcknowledgments ManualAcknowledgment[]

  // Help Desk
  supportTickets SupportTicket[]

  // Field Audits
  fieldAudits FieldAudit[]

  // Announcements
  announcementReads AnnouncementRead[]

  // Academy Program Enrollments
  programEnrollments ProgramEnrollment[]

  // Creative Assets
  creativeAssets CreativeAsset[]

  // PQS Feedback
  feedback          Feedback[]
  surveyResponses   SurveyResponse[]

  @@index([pipelineStage])
  @@index([assignedTo])
  @@index([createdAt])
}

enum InterestLevel {
  READY_TO_START
  ACTIVELY_SEEKING_FUNDING
  SERIOUSLY_CONSIDERING
  JUST_EXPLORING
  GATHERING_INFORMATION
}

enum LiquidityRange {
  UNDER_50K
  RANGE_50K_100K
  RANGE_100K_250K
  RANGE_250K_500K
  OVER_500K
}

enum PipelineStage {
  NEW_INQUIRY
  INITIAL_CONTACT
  DISCOVERY_CALL
  PRE_WORK_IN_PROGRESS
  PRE_WORK_COMPLETE
  INTERVIEW
  SELECTION_REVIEW
  SELECTED
  REJECTED
  WITHDRAWN
}

enum PreWorkStatus {
  NOT_STARTED
  IN_PROGRESS
  SUBMITTED
  UNDER_REVIEW
  APPROVED
  NEEDS_REVISION
}

// ============================================
// PRE-WORK MODULES
// ============================================

model PreWorkModule {
  id             String         @id @default(cuid())
  slug           String         @unique
  title          String
  description    String         @db.Text
  instructions   String         @db.Text
  sequence       Int
  isRequired     Boolean        @default(true)
  submissionType SubmissionType

  // Published schema (what prospects see)
  formSchema        Json?
  formSchemaVersion Int   @default(1)

  // Draft schema (admin edits)
  draftFormSchema Json?
  draftUpdatedAt  DateTime?
  draftUpdatedBy  String?

  // Relations
  submissions   PreWorkSubmission[]
  schemaHistory PreWorkSchemaVersion[]
  aiSuggestions PreWorkAISuggestion[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum SubmissionType {
  FORM
  FILE_UPLOAD
  TEXT
  CHECKLIST
  VIDEO_LOOM
  MIXED
}

model PreWorkSubmission {
  id            String           @id @default(cuid())
  prospectId    String
  moduleId      String
  status        SubmissionStatus @default(DRAFT)
  content       Json // Flexible content based on module type
  schemaVersion Int              @default(1) // Track which schema version was used
  submittedAt   DateTime?
  reviewedAt    DateTime?
  reviewedBy    String?
  reviewNotes   String?          @db.Text
  score         Int? // 1-10 internal score

  prospect Prospect      @relation(fields: [prospectId], references: [id], onDelete: Cascade)
  module   PreWorkModule @relation(fields: [moduleId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([prospectId, moduleId])
  @@index([prospectId])
  @@index([moduleId])
}

model PreWorkSchemaVersion {
  id          String   @id @default(cuid())
  moduleId    String
  version     Int
  formSchema  Json
  publishedAt DateTime @default(now())
  publishedBy String
  changeNotes String?  @db.Text

  module PreWorkModule @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  @@unique([moduleId, version])
}

model PreWorkAISuggestion {
  id           String    @id @default(cuid())
  moduleId     String
  suggestions  Json
  analysisData Json?
  generatedAt  DateTime  @default(now())
  dismissedAt  DateTime?
  appliedAt    DateTime?

  module PreWorkModule @relation(fields: [moduleId], references: [id], onDelete: Cascade)
}

enum SubmissionStatus {
  DRAFT
  SUBMITTED
  UNDER_REVIEW
  APPROVED
  NEEDS_REVISION
}

// ============================================
// PRE-WORK AI EVALUATION
// ============================================

model PreWorkEvaluation {
  id         String @id @default(cuid())
  prospectId String @unique

  // Dimension Scores (0-10)
  hustleScore        Float // 25% weight - Outreach volume, persistence, cold call willingness
  instructionScore   Float // 20% weight - Following format requirements, completeness
  communicationScore Float // 15% weight - Clarity, professionalism, video presence
  marketScore        Float // 15% weight - Research depth, territory understanding
  coachabilityScore  Float // 10% weight - Self-awareness, openness to feedback
  valuesScore        Float // 10% weight - Alignment with STC mission, integrity
  readinessScore     Float // 5% weight - Financial preparedness, timeline, commitment

  // Composite
  compositeScore  Float // Weighted 0-100
  confidenceLevel String // HIGH, MEDIUM, LOW

  // Qualitative
  greenFlags     Json // Array of strings
  redFlags       Json // Array of strings
  adminSummary   String @db.Text
  recommendation String // STRONG_YES, YES_WITH_COACHING, BORDERLINE, NO

  // Specific Analysis
  outreachCredibility String // HIGH, MEDIUM, LOW
  planRealismAnalysis String @db.Text

  // Meta
  systemSuggestions Json? // Suggested interview questions, coaching areas
  rawResponse       Json? // Full AI response for debugging

  // Relations
  prospect Prospect @relation(fields: [prospectId], references: [id], onDelete: Cascade)

  generatedAt DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ============================================
// AI CHATBOT CONVERSATIONS
// ============================================

model ChatConversation {
  id         String  @id @default(cuid())
  prospectId String? // Null for anonymous visitors
  sessionId  String // Browser session tracking
  title      String?

  messages ChatMessage[]
  prospect Prospect?     @relation(fields: [prospectId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([prospectId])
  @@index([sessionId])
}

model ChatMessage {
  id             String      @id @default(cuid())
  conversationId String
  role           MessageRole
  content        String      @db.Text
  metadata       Json? // citations, confidence, etc.

  conversation ChatConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([conversationId])
}

enum MessageRole {
  USER
  ASSISTANT
  SYSTEM
}

// ============================================
// DOCUMENT ACKNOWLEDGMENTS
// ============================================

model ProspectDocument {
  id             String       @id @default(cuid())
  prospectId     String
  documentType   DocumentType
  acknowledgedAt DateTime?
  signatureData  String?      @db.Text // Base64 signature if needed
  ipAddress      String?

  // Dropbox Sign integration fields
  signatureRequestId String?
  signatureStatus    SignatureStatus @default(PENDING)
  sentAt             DateTime?
  signedAt           DateTime?
  viewedAt           DateTime?
  expiresAt          DateTime?

  prospect Prospect @relation(fields: [prospectId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  @@unique([prospectId, documentType])
  @@index([prospectId])
  @@index([signatureRequestId])
}

enum SignatureStatus {
  PENDING
  SENT
  VIEWED
  SIGNED
  DECLINED
  EXPIRED
  ERROR
}

enum DocumentType {
  FDD_RECEIPT
  FRANCHISE_AGREEMENT
  TERRITORY_AGREEMENT
  NDA
  PRE_WORK_TERMS
}

// ============================================
// DOCUMENT MANAGEMENT SYSTEM
// ============================================

model Document {
  id String @id @default(cuid())

  // Document metadata
  title       String
  description String?     @db.Text
  docType     DocType
  category    DocCategory

  // Version control
  version  Int        @default(1)
  parentId String? // Previous version
  parent   Document?  @relation("DocumentVersions", fields: [parentId], references: [id])
  versions Document[] @relation("DocumentVersions")

  // File storage (Supabase)
  fileUrl  String // Supabase storage URL
  fileName String
  fileSize Int // Bytes
  mimeType String

  // Access control
  isPublic       Boolean @default(false)
  franchiseeOnly Boolean @default(false)

  // Expiration tracking
  expiresAt      DateTime?
  reminderSentAt DateTime?

  // Ownership
  uploadedById    String?
  uploadedByEmail String?

  // Relations
  franchiseeDocuments FranchiseeDocument[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([docType])
  @@index([category])
  @@index([expiresAt])
}

model FranchiseeDocument {
  id String @id @default(cuid())

  franchiseeAccountId String
  franchiseeAccount   FranchiseeAccount @relation(fields: [franchiseeAccountId], references: [id], onDelete: Cascade)

  documentId String
  document   Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  // Signature tracking (links to existing ProspectDocument for e-sign)
  prospectDocumentId String?

  // Acknowledgment tracking
  acknowledgedAt DateTime?
  acknowledgedBy String?

  // Status
  status FranchiseeDocStatus @default(PENDING)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([franchiseeAccountId, documentId])
  @@index([franchiseeAccountId])
  @@index([status])
}

enum DocType {
  FDD // Franchise Disclosure Document
  FRANCHISE_AGREEMENT
  TERRITORY_AGREEMENT
  OPERATIONS_MANUAL
  TRAINING_MATERIAL
  MARKETING_ASSET
  COMPLIANCE_CERT
  INSURANCE_CERT
  LEGAL_NOTICE
  TEMPLATE
  OTHER
}

enum DocCategory {
  LEGAL
  OPERATIONS
  MARKETING
  TRAINING
  COMPLIANCE
  FINANCIAL
}

enum FranchiseeDocStatus {
  PENDING
  VIEWED
  ACKNOWLEDGED
  SIGNATURE_PENDING
  SIGNED
  EXPIRED
}

// ============================================
// ACTIVITY LOG (CRM)
// ============================================

model ProspectActivity {
  id           String       @id @default(cuid())
  prospectId   String
  activityType ActivityType
  description  String
  metadata     Json?
  performedBy  String? // Admin email

  prospect Prospect @relation(fields: [prospectId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([prospectId])
  @@index([createdAt])
}

enum ActivityType {
  FORM_SUBMITTED
  EMAIL_SENT
  SMS_SENT
  SMS_RECEIVED
  CALL_LOGGED
  STAGE_CHANGED
  PRE_WORK_STARTED
  PRE_WORK_SUBMITTED
  DOCUMENT_SIGNED
  DOCUMENT_DOWNLOADED
  NOTE_ADDED
  SCORE_UPDATED
  LOGIN
  PAGE_VIEW
  WORKFLOW_TRIGGERED
}

// ============================================
// ADMIN NOTES
// ============================================

model ProspectNote {
  id          String  @id @default(cuid())
  prospectId  String
  content     String  @db.Text
  authorEmail String
  isPinned    Boolean @default(false)

  prospect Prospect @relation(fields: [prospectId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([prospectId])
}

// ============================================
// RAG KNOWLEDGE BASE
// ============================================

model KnowledgeDocument {
  id          String            @id @default(cuid())
  title       String
  slug        String            @unique
  category    KnowledgeCategory
  articleType WikiArticleType   @default(ARTICLE)
  content     String            @db.Text
  excerpt     String?           @db.Text
  isPublic    Boolean           @default(true)
  scope       KnowledgeScope    @default(ACADEMY)

  // Author
  authorId    String?
  authorName  String?
  authorImage String?

  // SOP-specific fields (only used when articleType = SOP)
  sopVersion  String?
  sopOwner    String?
  sopRequired Boolean           @default(false)

  // Linking
  linkedFrom WikiLink[] @relation("LinkedFrom")
  linkedTo   WikiLink[] @relation("LinkedTo")

  chunks KnowledgeChunk[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([slug])
  @@index([articleType])
  @@index([category])
}

model WikiLink {
  id     String            @id @default(cuid())
  fromId String
  from   KnowledgeDocument @relation("LinkedFrom", fields: [fromId], references: [id], onDelete: Cascade)
  toId   String
  to     KnowledgeDocument @relation("LinkedTo", fields: [toId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([fromId, toId])
  @@index([fromId])
  @@index([toId])
}

enum WikiArticleType {
  ARTICLE
  SOP
  GUIDE
  FAQ
}

enum KnowledgeScope {
  PUBLIC // Website visitors only
  ACADEMY // Selected franchisees only
  BOTH // Available to all
}

enum KnowledgeCategory {
  FRANCHISE_FAQ
  BUSINESS_MODEL
  TERRITORY_INFO
  TRAINING_SUPPORT
  TESTIMONIALS
  CHESS_BENEFITS
  COMPANY_INFO
  INVESTMENT
  PROCESS
  OPERATIONS // Academy-only: SOPs, procedures
  MARKETING // Academy-only: marketing playbooks
  SALES // Academy-only: pricing, negotiations
  LEGAL // Academy-only: contracts, compliance
  FINANCE
  ADMINISTRATION
}

model KnowledgeChunk {
  id         String  @id @default(cuid())
  documentId String
  content    String  @db.Text
  embedding  String? @db.Text // Store as JSON string until pgvector is installed
  tokenCount Int
  sequence   Int

  document KnowledgeDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([documentId])
}

// ============================================
// TERRITORY / MARKET MANAGEMENT
// ============================================

model Market {
  id          String       @id @default(cuid())
  name        String
  state       String
  description String?      @db.Text
  status      MarketStatus @default(AVAILABLE)

  // Territory boundaries (GeoJSON polygon)
  boundaryGeoJson Json?
  centerLat       Float?
  centerLng       Float?
  radiusMiles     Float? // Protected territory radius

  // Territory creation metadata
  boundaryType  BoundaryType? // How the territory was created
  travelMode    TravelMode? // For isochrone territories
  travelMinutes Int? // For isochrone territories
  zipCodes      String[] // For ZIP-based territories
  color         String? // Hex color for map rendering

  // Legacy fields (for backward compatibility)
  latitude  Float?
  longitude Float?

  // Demographics (cached from external API)
  population             Int?
  medianIncome           Int?
  medianAge              Float?
  householdsWithChildren Int?
  totalHouseholds        Int?
  childrenUnder18        Int?
  children5to12          Int? // Primary target demo for STC
  schoolCount            Int?
  competitorCount        Int?
  demographicsUpdatedAt  DateTime?

  // Scoring
  territoryScore Float? // Composite viability score 0-100

  // Franchisee assignment
  franchiseeAccountId String?
  franchiseeAccount   FranchiseeAccount? @relation(fields: [franchiseeAccountId], references: [id])
  assignedAt          DateTime?

  // Legacy field - kept for migration
  franchiseeId String? // Deprecated: use franchiseeAccountId

  notes      String?   @db.Text
  metadata   Json? // Flexible extra data
  launchDate DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  demographicSnapshots DemographicSnapshot[]
  poiSearches          POISearch[]
  territoryNotes       TerritoryNote[]

  @@unique([name, state])
  @@index([franchiseeAccountId])
  @@index([status])
  @@index([territoryScore])
}

enum MarketStatus {
  AVAILABLE // Open for franchise sales
  RESERVED // In negotiation with prospect
  SOLD // Franchisee assigned
  ACTIVE // Operating franchise
  COMING_SOON // Future expansion
  UNAVAILABLE // Corporate or restricted
}

enum BoundaryType {
  ISOCHRONE // Drive/walk time
  ISODISTANCE // Radius circle
  ZIP_CODES // ZIP code selection
  ADMIN_BOUNDARY // State/county/city
  MANUAL_DRAW // Freehand polygon
}

enum TravelMode {
  DRIVING
  WALKING
  CYCLING
  PUBLIC_TRANSIT
}

// ============================================
// TERRITORY MAP WORKSPACES
// ============================================

model TerritoryMap {
  id          String    @id @default(cuid())
  name        String
  description String?   @db.Text
  centerLat   Float     @default(39.8283)
  centerLng   Float     @default(-98.5795)
  zoomLevel   Int       @default(4)
  layers      Json?
  isShared    Boolean   @default(false)
  shareToken  String?   @unique
  shareExpiry DateTime?
  createdBy   String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  datasets Dataset[]

  @@index([createdBy])
  @@index([shareToken])
}

model DemographicSnapshot {
  id         String   @id @default(cuid())
  marketId   String?
  market     Market?  @relation(fields: [marketId], references: [id], onDelete: Cascade)
  geometry   Json
  dataSource String
  indicators Json
  fetchedAt  DateTime @default(now())

  @@index([marketId])
}

model POISearch {
  id          String   @id @default(cuid())
  marketId    String?
  market      Market?  @relation(fields: [marketId], references: [id], onDelete: Cascade)
  query       String
  category    String
  bounds      Json
  results     Json
  resultCount Int      @default(0)
  searchedAt  DateTime @default(now())

  @@index([marketId])
}

model Dataset {
  id             String         @id @default(cuid())
  name           String
  sourceType     DataSourceType @default(CSV)
  territoryMapId String?
  territoryMap   TerritoryMap?  @relation(fields: [territoryMapId], references: [id], onDelete: SetNull)
  columns        Json
  rowCount       Int            @default(0)
  geocodedCount  Int            @default(0)
  fileUrl        String?
  uploadedBy     String
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  dataPoints DataPoint[]

  @@index([uploadedBy])
}

enum DataSourceType {
  CSV
  EXCEL
  MANUAL
}

model DataPoint {
  id         String   @id @default(cuid())
  datasetId  String
  dataset    Dataset  @relation(fields: [datasetId], references: [id], onDelete: Cascade)
  lat        Float?
  lng        Float?
  address    String?
  zipCode    String?
  properties Json
  createdAt  DateTime @default(now())

  @@index([datasetId])
  @@index([lat, lng])
}

model TerritoryNote {
  id        String   @id @default(cuid())
  marketId  String
  market    Market   @relation(fields: [marketId], references: [id], onDelete: Cascade)
  authorId  String
  content   String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([marketId])
}

model ScoringConfig {
  id                         String   @id @default(cuid())
  region                     String   @default("US")
  childrenDensityWeight      Float    @default(0.25)
  householdIncomeWeight      Float    @default(0.20)
  householdsWithKidsWeight   Float    @default(0.15)
  competitorSaturationWeight Float    @default(0.15)
  populationDensityWeight    Float    @default(0.10)
  schoolDensityWeight        Float    @default(0.10)
  educationLevelWeight       Float    @default(0.05)
  childrenDensityBenchmark   Float    @default(500)
  householdIncomeBenchmark   Float    @default(75000)
  schoolDensityBenchmark     Float    @default(2)
  createdAt                  DateTime @default(now())
  updatedAt                  DateTime @updatedAt

  @@unique([region])
}

// ============================================
// EMAIL NOTIFICATIONS
// ============================================

model NotificationLog {
  id             String           @id @default(cuid())
  type           NotificationType
  recipientEmail String
  subject        String
  sentAt         DateTime         @default(now())
  metadata       Json?

  @@index([type])
  @@index([sentAt])
}

enum NotificationType {
  NEW_INQUIRY
  PRE_WORK_COMPLETED
  DAILY_DIGEST
  HIGH_SCORE_ALERT
  WELCOME_EMAIL
  PRE_WORK_REMINDER
}

// ============================================
// STORY TIME ACADEMY
// ============================================

model AcademyPhase {
  id          String  @id @default(cuid())
  slug        String  @unique
  title       String
  description String? @db.Text
  order       Int     @default(0)
  dayStart    Int? // Optional: for onboarding programs (e.g., day 1)
  dayEnd      Int? // Optional: for onboarding programs (e.g., day 7)
  imageUrl    String?

  // Legacy fields (kept during migration, will be removed in Phase 4)
  sequence Int?
  duration String? // e.g., "Week 1-2" — replaced by dayStart/dayEnd

  // Link to Academy Program
  programId String?
  program   AcademyProgram? @relation(fields: [programId], references: [id])

  modules AcademyModule[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([programId])
}

model AcademyModule {
  id          String            @id @default(cuid())
  phaseId     String
  slug        String            @unique
  title       String
  description String?           @db.Text
  order       Int               @default(0)
  moduleType  AcademyModuleType @default(ASSIGNMENT)
  points      Int               @default(10)
  duration    Int? // Estimated minutes
  resourceUrl String? // Link to external resource

  // Onboarding-specific fields (optional — only used for ONBOARDING programs)
  owner                ModuleOwner? // Who does this task?
  verificationType     VerificationType? // How to verify completion?
  targetDay            Int? // Target completion day (1-90)
  isMilestone          Boolean           @default(false)
  notifyFranchisor     Boolean           @default(false)
  franchisorActionText String? // "Set up their G Suite account"
  richDescription      String?           @db.Text // HTML from TipTap editor

  // Step guide fields (admin-editable explainer content)
  stepWhat       String?  @db.Text // "What is this step?"
  stepHow        String?  @db.Text // "How do you do it?"
  stepWhy        String?  @db.Text // "Why is this important?"
  dataFields     Json?              // Array of {key, label, type, required} for data collection
  resourcePageId String?            // ManualPage ID for "View Resource Guide" overlay
  sectionOrder   Json?              // Array of section IDs: "step-guide", block IDs, "data-collection"

  // Completion email — auto-send via Gmail when franchisee completes this module
  completionEmailTemplateId String?
  completionEmailTemplate   EmailTemplate? @relation("CompletionEmailModules", fields: [completionEmailTemplateId], references: [id], onDelete: SetNull)

  // Legacy fields (kept during migration, will be removed in Phase 4)
  content  String? @db.Text // Old HTML/Markdown — migrated to ContentBlock
  sequence Int? // Old ordering — replaced by order
  quizData Json? // Old quiz JSON — migrated to QUIZ ContentBlocks

  phase           AcademyPhase      @relation(fields: [phaseId], references: [id], onDelete: Cascade)
  progress        AcademyProgress[]
  contentBlocks   ContentBlock[]
  franchisorTodos FranchisorTodo[]  @relation("ModuleTodos")
  linkedResources ModuleResource[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([phaseId])
}

enum AcademyModuleType {
  VIDEO
  READING
  QUIZ
  CHECKLIST
  ASSIGNMENT
  RESOURCE
}

model AcademyProgress {
  id           String         @id @default(cuid())
  prospectId   String
  moduleId     String
  status       ProgressStatus @default(NOT_STARTED)
  startedAt    DateTime?
  completedAt  DateTime?
  pointsEarned Int            @default(0)
