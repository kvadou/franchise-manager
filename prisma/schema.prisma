// ============================================
// VISITOR TRACKING & ANALYTICS
// ============================================

// Long-lived visitor record (persists across browser sessions)
model Visitor {
  id         String  @id @default(cuid())
  visitorId  String  @unique // Stored in localStorage, persists across sessions
  prospectId String? // Links when visitor converts to prospect

  // Aggregate stats
  firstSeenAt     DateTime @default(now())
  lastSeenAt      DateTime @default(now())
  totalSessions   Int      @default(1)
  totalPageViews  Int      @default(0)
  totalTimeOnSite Int      @default(0) // Total seconds across all sessions

  // Relations
  prospect Prospect?        @relation(fields: [prospectId], references: [id], onDelete: SetNull)
  sessions VisitorSession[]

  @@index([prospectId])
  @@index([lastSeenAt])
}

// Individual browsing session
model VisitorSession {
  id         String  @id @default(cuid())
  visitorId  String // FK to Visitor
  sessionId  String  @unique // The short-lived session ID (same as Earl chat uses)
  prospectId String? // Denormalized for easier queries

  // UTM Tracking
  utmSource   String? // facebook, google, instagram, etc.
  utmMedium   String? // cpc, social, email, etc.
  utmCampaign String? // spring_2026_launch, etc.
  utmTerm     String? // keyword for paid search
  utmContent  String? // ad variant identifier

  // Traffic source
  referrer       String? // Full referrer URL
  referrerDomain String? // Just the domain for easier grouping
  landingPage    String // First page they landed on

  // Device & Browser info
  deviceType     String? // mobile, tablet, desktop
  browser        String? // Chrome, Safari, Firefox, etc.
  browserVersion String?
  os             String? // iOS, Android, Windows, macOS, etc.
  osVersion      String?
  screenWidth    Int?
  screenHeight   Int?
  language       String? // Browser language
  timezone       String? // User's timezone

  // Location (can be derived from IP later)
  ipAddress String?
  country   String?
  region    String?
  city      String?

  // Session metrics
  startedAt      DateTime  @default(now())
  lastActivityAt DateTime  @default(now())
  endedAt        DateTime? // Set when session ends/times out
  totalDuration  Int       @default(0) // Seconds
  pageViewCount  Int       @default(0)

  // Conversion tracking
  hadEarlChat     Boolean   @default(false)
  submittedForm   Boolean   @default(false)
  formSubmittedAt DateTime?

  // Relations
  visitor   Visitor    @relation(fields: [visitorId], references: [id], onDelete: Cascade)
  pageViews PageView[]

  @@index([visitorId])
  @@index([prospectId])
  @@index([startedAt])
  @@index([utmSource])
  @@index([utmCampaign])
}

// Individual page view
model PageView {
  id        String @id @default(cuid())
  sessionId String // FK to VisitorSession

  // Page info
  pagePath  String // /about, /contact, etc.
  pageTitle String? // Document title
  pageType  String? // home, about, contact, faq, etc.

  // Timing
  enteredAt DateTime  @default(now())
  exitedAt  DateTime?
  duration  Int? // Seconds on page

  // Engagement (optional, for future use)
  scrollDepth Int? // Percentage scrolled (0-100)
  clickCount  Int? // Number of clicks on page

  // Navigation
  previousPage String? // Where they came from (internal)

  // Relations
  session VisitorSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@index([pagePath])
  @@index([enteredAt])
}

// ============================================
// CUSTOM EVENT TRACKING
// ============================================

// Track specific user interactions: video plays, downloads, FAQ opens, scroll depth, etc.
model CustomEvent {
  id        String @id @default(cuid())
  sessionId String // FK to VisitorSession.sessionId
  visitorId String // FK to Visitor.visitorId

  // Event details
  eventType     EventType
  eventName     String // e.g., "video_play", "pdf_download", "faq_open"
  eventCategory String? // e.g., "engagement", "conversion", "navigation"

  // Event data (flexible JSON for any additional context)
  pagePath    String // Page where event occurred
  elementId   String? // DOM element ID if applicable
  elementText String? // Button/link text
  metadata    Json? // Additional event-specific data

  // For scroll tracking
  scrollDepth Int? // Percentage (0-100)

  // For video/media tracking
  mediaUrl      String? // URL of video/media
  mediaDuration Int? // Total duration in seconds
  mediaPosition Int? // Current position in seconds

  // For download tracking
  fileName String? // Downloaded file name
  fileType String? // pdf, doc, etc.

  // Timing
  timestamp DateTime @default(now())

  @@index([sessionId])
  @@index([visitorId])
  @@index([eventType])
  @@index([eventName])
  @@index([timestamp])
}

enum EventType {
  VIDEO_PLAY
  VIDEO_PAUSE
  VIDEO_COMPLETE
  VIDEO_PROGRESS // For 25%, 50%, 75% milestones
  DOWNLOAD
  FAQ_OPEN
  FAQ_CLOSE
  SCROLL_MILESTONE // 25%, 50%, 75%, 100%
  BUTTON_CLICK
  LINK_CLICK
  FORM_FOCUS
  FORM_ABANDON
  CTA_CLICK
  SHARE_CLICK
  CHAT_OPEN
  CHAT_MESSAGE
  TERRITORY_SEARCH
  CALENDAR_CLICK
  ACCORDION_TOGGLE
  TAB_SWITCH
  MODAL_OPEN
  MODAL_CLOSE
}

// ============================================
// SESSION REPLAY
// ============================================

// Stores session replay data for playback
model SessionReplay {
  id        String @id @default(cuid())
  sessionId String @unique // FK to VisitorSession.sessionId
  visitorId String // FK to Visitor.visitorId

  // Recording metadata
  startedAt  DateTime  @default(now())
  endedAt    DateTime?
  duration   Int       @default(0) // Seconds
  eventCount Int       @default(0)

  // Page dimensions for proper scaling during playback
  viewportWidth  Int?
  viewportHeight Int?
  pageWidth      Int?
  pageHeight     Int?

  // Status
  isComplete Boolean @default(false)

  // Events stored as compressed JSON array
  // Format: [{ t: timestamp_ms, type: "mouse"|"click"|"scroll"|"resize", x?, y?, scrollTop?, scrollLeft?, ... }]
  events Json @default("[]")

  // Metadata
  pagePath  String // Initial page
  userAgent String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([sessionId])
  @@index([visitorId])
  @@index([startedAt])
}

// ============================================
// A/B TESTING
// ============================================

// A/B Test definition
model ABTest {
  id          String  @id @default(cuid())
  slug        String  @unique
  name        String
  description String? @db.Text

  // Test configuration
  targetPage String // Page path where test runs
  element    String // CSS selector or component name
  status     ABTestStatus @default(DRAFT)

  // Variants stored as JSON: [{ id: "control", name: "Control", weight: 50, config: {...} }, ...]
  variants Json @default("[]")

  // Traffic allocation (0-100%)
  trafficPercent Int @default(100)

  // Timing
  startDate DateTime?
  endDate   DateTime?

  // Results tracking
  assignments ABTestAssignment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([targetPage])
}

enum ABTestStatus {
  DRAFT
  RUNNING
  PAUSED
  COMPLETED
  ARCHIVED
}

// Tracks which variant a visitor was assigned
model ABTestAssignment {
  id        String @id @default(cuid())
  testId    String
  visitorId String // Visitor.visitorId
  variantId String // ID from the variants JSON

  // Conversion tracking
  converted       Boolean   @default(false)
  convertedAt     DateTime?
  conversionValue Float? // Optional value (e.g., revenue)

  test ABTest @relation(fields: [testId], references: [id], onDelete: Cascade)

  assignedAt DateTime @default(now())

  @@unique([testId, visitorId])
  @@index([testId])
  @@index([visitorId])
  @@index([variantId])
}

