  UPLOAD
  URL
}

model CreativeAsset {
  id          String          @id @default(cuid())
  title       String
  description String?         @db.Text
  category    AssetCategory   @default(OTHER)
  sourceType  AssetSourceType

  // Canva fields
  canvaDesignId     String?
  canvaEmbedUrl     String?
  canvaThumbnailUrl String?

  // Upload fields
