enum AssetCategory {
  LOGOS
  SOCIAL_MEDIA
  FLYERS_PRINT
  EMAIL_TEMPLATES
  PRESENTATIONS
  LEGAL_DOCS
  PHOTOS_MEDIA
  OTHER
}

enum AssetSourceType {
