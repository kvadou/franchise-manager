// ============================================
// LEAD SOURCE MANAGEMENT
// ============================================

enum LeadSourceCategory {
  PAID_SEARCH
  PAID_SOCIAL
  ORGANIC_SEARCH
  ORGANIC_SOCIAL
  REFERRAL
  EMAIL
  EVENTS
  PARTNERSHIPS
  DIRECT
  OTHER
}

model LeadSource {
  id        String             @id @default(cuid())
  slug      String             @unique
  name      String
  category  LeadSourceCategory
  utmSource String? // Maps to utm_source values
  utmMedium String? // Maps to utm_medium values
  isActive  Boolean            @default(true)
  notes     String?            @db.Text
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt

  spends CampaignSpend[]

  @@index([category])
  @@index([isActive])
}

model CampaignSpend {
  id           String     @id @default(cuid())
  leadSourceId String
  leadSource   LeadSource @relation(fields: [leadSourceId], references: [id], onDelete: Cascade)
  month        Int // 1-12
  year         Int
  amount       Decimal    @db.Decimal(10, 2)
  notes        String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@unique([leadSourceId, month, year])
  @@index([leadSourceId])
  @@index([year, month])
}

// Stores uploaded files in PostgreSQL (no external storage dependency)
model UploadedFile {
  id        String   @id @default(cuid())
  fileName  String
  mimeType  String
  fileSize  Int
  data      Bytes    // File binary stored in Postgres
  uploadedBy String  // Prospect ID or admin user ID
  context   String?  // e.g. "bootcamp-docs", "compliance"
  createdAt DateTime @default(now())

  @@index([uploadedBy])
}

// ============================================
// PRODUCT QUALITY SCORE (PQS) — Franchisee Feedback
// ============================================

model Feedback {
  id          String          @id @default(cuid())
  prospectId  String
  prospect    Prospect        @relation(fields: [prospectId], references: [id], onDelete: Cascade)

  type        FeedbackType    // PAGE_FEEDBACK, MILESTONE_COMPLETION, FEATURE_RATING
  trigger     FeedbackTrigger // PERSISTENT_WIDGET, MILESTONE_PROMPT, MANUAL
  rating      Int             // 1-5
  comment     String?         @db.Text
  pageUrl     String?
  userRole    String          // PROSPECT, ADMIN
  metadata    Json?           // Extra context (moduleId, taskId, etc.)

  createdAt   DateTime        @default(now())

  @@index([prospectId])
  @@index([type])
  @@index([createdAt])
  @@index([pageUrl])
}

model SurveyResponse {
  id          String     @id @default(cuid())
  prospectId  String
  prospect    Prospect   @relation(fields: [prospectId], references: [id], onDelete: Cascade)

  surveyType  SurveyType // MILESTONE_PREWORK, MILESTONE_30DAY, MILESTONE_90DAY, QUARTERLY

  npsScore         Int   // 0-10
  cesScore         Int   // 1-7
  usabilityScore   Int   // 1-5
  helpfulnessScore Int   // 1-5
  reliabilityScore Int   // 1-5

  whatWorksWell  String? @db.Text
  whatToImprove  String? @db.Text

  createdAt   DateTime   @default(now())

  @@index([prospectId])
  @@index([surveyType])
  @@index([createdAt])
}

model ProductQualityScore {
  id    String @id @default(cuid())
  year  Int
  month Int

  npsScore       Float // -100 to +100
  cesScore       Float // 1-7 average

  usabilityAvg   Float // 1-5
  helpfulnessAvg Float // 1-5
  reliabilityAvg Float // 1-5

  microFeedbackCount Int
  microFeedbackAvg   Float

  surveyResponseCount Int
  totalFeedbackCount  Int

  previousNps Float?
  trend       ScoreTrend // Reuse existing enum

  breakdown   Json?

  createdAt   DateTime @default(now())

  @@unique([year, month])
  @@index([year, month])
}

model FeedbackThrottle {
  id            String    @id @default(cuid())
  prospectId    String
  lastPromptAt  DateTime
  lastDismissAt DateTime?
  promptCount   Int       @default(0)

  @@unique([prospectId])
  @@index([prospectId])
}

model FeedbackChangelog {
  id          String    @id @default(cuid())
  title       String
  description String    @db.Text
  category    String?
  createdBy   String
  publishedAt DateTime?

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

enum FeedbackType {
  PAGE_FEEDBACK
  MILESTONE_COMPLETION
  FEATURE_RATING
}

enum FeedbackTrigger {
  PERSISTENT_WIDGET
  MILESTONE_PROMPT
  MANUAL
}

enum SurveyType {
  MILESTONE_PREWORK
  MILESTONE_30DAY
  MILESTONE_90DAY
  QUARTERLY
}
